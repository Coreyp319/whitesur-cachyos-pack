# Runtime artifacts (regenerated by the installers — not source)
2-settings-refine/icons/*/icon-theme.cache
2-settings-refine/icons/*/.baked-tone

# Backups any layer may drop next to originals
*.orig
*.bak

# Python bytecode
__pycache__/
*.pyc

# makepkg / AUR build output (if a PKGBUILD is ever built in-tree)
*.pkg.tar.*
*.src.tar.*

# Blender MCP forge — per-session runtime state + render scratch (never source;
# the lane/port is ephemeral env, the committed products are hero_core.{png,glb})
.blender-mcp/
*.blend1
